# 共通設定
TIMEZONE=Asia/Tokyo

# TikTok Credentials (data-fetcher で使用)
# TikTok Live Backstage へのログインに使用します
TIKTOK_USERNAME=your_tiktok_id
TIKTOK_PASSWORD=your_tiktok_password

# Google Sheets API 設定 (全サービスで使用)
# メインのデータ管理用スプレッドシートのID
GOOGLE_SHEET_ID=your_google_sheet_id_here
# マスターデータ管理用スプレッドシートのID (必要に応じて)
GOOGLE_MASTER_SHEET_ID=your_master_sheet_id_here
# コンテナ内でのサービスアカウント JSON のパス
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/service-account.json

# Tikfinity API 設定 (corporate-site で使用)
# ガチャ機能のポイント消費に使用します
TIKFINITY_API_TOKEN=your_tikfinity_api_token_here

# 通知設定 (data-fetcher で使用)
# 処理結果やエラーの通知先 Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here