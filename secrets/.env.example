# .env.common
TIMEZONE=Asia/Tokyo

# .env.google
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_MASTER_SHEET_ID=your_master_sheet_id_here
# GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/service-account.json

# .env.corporate
TIKFINITY_API_TOKEN=your_tikfinity_api_token_here

# .env.fetcher
TIKTOK_USERNAME=your_tiktok_id
TIKTOK_PASSWORD=your_tiktok_password
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# 運用上の注意: 
# 1. service-account.json を配置してください。
